########################################
# mod-sod-world configuration
########################################
#
#    SodWorld.Enable
#        Description: Master switch for the module. When disabled, the shared
#                     Season of Discovery encounters are inert (the Decrepit
#                     Phylactery summons nothing). The DB rows remain but the
#                     module-scripted behavior is a no-op.
#        Default:     1 - (Enabled)
#                     0 - (Disabled)
#

SodWorld.Enable = 1

#
#    SodWorld.AwakenedLich.DespawnSeconds
#        Description: How long the summoned Awakened Lich lingers before it
#                     despawns if not killed (the summon is also removed on
#                     death). Lower values make the encounter resettable sooner.
#        Default:     300 - (5 minutes)
#

SodWorld.AwakenedLich.DespawnSeconds = 300

#
#    SodWorld.AwakenedLich.Level
#        Description: Level the summoned Awakened Lich spawns at. Its health, mana,
#                     and damage scale from this level (via the creature template's
#                     stat modifiers). Applied to the next summon after a change;
#                     `.reload config` is enough -- no restart.
#        Default:     25
#

SodWorld.AwakenedLich.Level = 25

#
#    SodWorld.Phylactery.SummonRange
#        Description: How close (yards) the player must be to the Slumbering
#                     Bones to use the Decrepit Phylactery and summon the Lich.
#        Default:     10
#

SodWorld.Phylactery.SummonRange = 10

#
#    SodWorld.SupplyDrop.P{1..4}Chance
#        Description: Percent chance for a "Supply Shipment" crate to drop when a
#                     player opens one of the SoD world chests wired up for that
#                     phase (P1 item level 10, P2 25, P3 40, P4 50). These tune the
#                     Chance of the loot rows seeded by sod_world_supply_drops.sql;
#                     applied at startup and on `.reload config`. 0 disables that
#                     tier's drop. When SodWorld.Enable = 0 all four are forced to 0.
#        Default:     P1 10, P2 10, P3 10, P4 5
#

SodWorld.SupplyDrop.P1Chance = 10
SodWorld.SupplyDrop.P2Chance = 10
SodWorld.SupplyDrop.P3Chance = 10
SodWorld.SupplyDrop.P4Chance = 5
